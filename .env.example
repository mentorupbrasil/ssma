# Database (Neon: use pooled URL em runtime; DIRECT_URL opcional para migrate local)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth
AUTH_SECRET="generate-a-secure-random-string-here"
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# E-mail (Resend — opcional; sem chave, registra histórico sem enviar)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Unimetra <contato@sua-clinica.com.br>"

# Storage na nuvem (Vercel Blob — opcional; sem token, usa disco local em dev)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# SyncPay (assinatura mensal Unimetra — apenas backend; sem NEXT_PUBLIC)
SYNCPAY_BASE_URL=
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
SYNCPAY_PLAN_TOKEN=
SYNCPAY_WEBHOOK_TOKEN=
UNIMETRA_MONTHLY_AMOUNT=
UNIMETRA_BILLING_GRACE_DAYS=5
SUBSCRIPTION_ENFORCEMENT_ENABLED=false
