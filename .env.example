# Database
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Auth
AUTH_SECRET="generate-a-secure-random-string-here"
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Dados institucionais da clínica (preencher com dados reais antes de publicar)
NEXT_PUBLIC_CLINIC_NAME="Unimetra"
NEXT_PUBLIC_CLINIC_PHONE=""
NEXT_PUBLIC_CLINIC_WHATSAPP=""
NEXT_PUBLIC_CLINIC_EMAIL=""
NEXT_PUBLIC_CLINIC_INSTAGRAM=""

# Localização
NEXT_PUBLIC_CLINIC_ADDRESS=""
NEXT_PUBLIC_CLINIC_CITY=""
NEXT_PUBLIC_CLINIC_STATE=""
NEXT_PUBLIC_CLINIC_POSTAL_CODE=""
NEXT_PUBLIC_CLINIC_OPENING_HOURS=""
# Link curto do Google Maps (botão "Abrir no Maps") — goo.gl funciona aqui
NEXT_PUBLIC_CLINIC_MAPS_URL="https://maps.app.goo.gl/XDip6f7qFYn7L9JR8"
# Embed: deixe vazio para gerar automaticamente via LAT/LNG ou endereço
# Não coloque link goo.gl em MAPS_EMBED (não funciona em iframe)
NEXT_PUBLIC_CLINIC_MAPS_EMBED=""
NEXT_PUBLIC_CLINIC_MAPS_LAT="-5.524725"
NEXT_PUBLIC_CLINIC_MAPS_LNG="-47.479393"
