generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CLINIC_ADMIN
  RECEPTION
  COMMERCIAL
  FINANCIAL
  SST_TECHNICIAN
  HEALTH_PROFESSIONAL
  COMPANY_HR
  READ_ONLY
  ADMIN
  RECEPCAO
  MEDICO
  TECNICO
  FINANCEIRO
  EMPRESA
  VISUALIZADOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClinicStatus {
  ATIVA
  TRIAL
  SUSPENSA
  CANCELADA
  BLOQUEADA
}

enum ClinicPlan {
  TRIAL
  BASICO
  PROFISSIONAL
  ENTERPRISE
}

model Clinic {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  status          ClinicStatus @default(ATIVA)
  plan            ClinicPlan   @default(TRIAL)
  responsibleName String?
  email           String?
  whatsapp        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  users           User[]
  companies       Company[]
  patients        Patient[]
  referrals       Referral[]
  preReferrals    PublicReferralRequest[]
  documents       Document[]
  leads           Lead[]
  quotes          Quote[]
  appointments    Appointment[]
  exams           Exam[]
  auditLogs       AuditLog[]
  contactMessages ContactMessage[]
}

enum CompanyStatus {
  ATIVA
  INATIVA
  PENDENTE
  BLOQUEADA
}

enum CompanySize {
  PEQUENA
  MEDIA
  GRANDE
}

enum CompanyContractType {
  AVULSO
  MENSAL
  ANUAL
  EM_NEGOCIACAO
}

enum CompanyContactType {
  SITE
  WHATSAPP
  TELEFONE
  EMAIL
  VISITA
  COMERCIAL
  OUTRO
}

enum CompanyHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  EMPLOYEE_ADDED
  REFERRAL_CREATED
  QUOTE_SENT
  DOCUMENT_ATTACHED
  PORTAL_ENABLED
  PORTAL_DISABLED
  USER_CREATED
  CONTACT_ADDED
}

enum PatientStatus {
  ATIVO
  INATIVO
  AFASTADO
  DESLIGADO
  PENDENTE
}

enum PatientHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  REFERRAL_CREATED
  APPOINTMENT_SCHEDULED
  ATTENDANCE_STARTED
  ATTENDANCE_COMPLETED
  DOCUMENT_ATTACHED
  ASO_AVAILABLE
  COMPANY_LINKED
}

enum ExamCategory {
  CLINICO_OCUPACIONAL
  COMPLEMENTAR
  LABORATORIAL
  IMAGEM
  TOXICOLOGICO
  AVALIACAO_ESPECIALIZADA
  OUTRO
}

enum ExamStatus {
  ATIVO
  INATIVO
  EM_REVISAO
}

enum ExamPreparationType {
  SEM_PREPARO
  PREPARO_NECESSARIO
  JEJUM_NECESSARIO
  ATENCAO_ESPECIAL
  VERIFICAR_EXAME
  ORIENTACAO_ESPECIFICA
}

enum ExamDeadlineType {
  NO_DIA
  DIAS_UTEIS
  CONFORME_AGENDAMENTO
  CONFORME_LABORATORIO
}

enum ExamHistoryAction {
  CREATED
  UPDATED
  PREPARATION_CHANGED
  DEADLINE_CHANGED
  STATUS_CHANGED
  PUBLISHED
  UNPUBLISHED
  DUPLICATED
}

enum ClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  MUDANCA_FUNCAO
  RETORNO_TRABALHO
}

enum ReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_AGENDAMENTO
  AGENDADO
  EM_ATENDIMENTO
  AGUARDANDO_RESULTADO
  AGUARDANDO_DOCUMENTO
  ASO_DISPONIVEL
  CONCLUIDO
  CANCELADO
}

enum ReferralSource {
  PORTAL
  ADMIN
  PRE_REFERRAL
  SITE
}

enum ReferralExamStatus {
  PENDENTE
  AGENDADO
  REALIZADO
  RESULTADO_DISPONIVEL
  CANCELADO
}

enum ReferralDocumentType {
  ASO
  GUIA
  LAUDO
  RESULTADO
  OUTRO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  FALTOU
  REAGENDADO
  CANCELADO
}

enum AppointmentHistoryAction {
  CREATED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  ATTENDANCE_STARTED
  COMPLETED
  NOTE_ADDED
  STATUS_CHANGED
}

enum LeadStatus {
  NOVO
  EM_ANALISE
  EM_CONTATO
  AGUARDANDO_RETORNO
  CONVERTIDO_ORCAMENTO
  PROPOSTA_ENVIADA
  FECHADO
  PERDIDO
  EXPIRADO
  ARQUIVADO
}

enum QuoteStatus {
  RASCUNHO
  EM_ANALISE
  ENVIADO
  AGUARDANDO_RESPOSTA
  APROVADO
  RECUSADO
  EXPIRADO
  CANCELADO
}

enum CommercialEntityType {
  LEAD
  QUOTE
  CONTACT
}

enum CommercialHistoryAction {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  WHATSAPP_OPENED
  EMAIL_SENT
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
  QUOTE_DUPLICATED
  COMPANY_LINKED
  REFERRAL_CREATED
  PORTAL_ENABLED
  ARCHIVED
}

enum QuoteRejectReason {
  VALOR
  SEM_RESPOSTA
  OUTRO_FORNECEDOR
  SEM_INTERESSE
  OUTRO
}

enum LeadType {
  ORCAMENTO
  CONTATO
  GERAL
}

enum PreReferralClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  RETORNO_TRABALHO
  MUDANCA_FUNCAO
  NAO_SEI_INFORMAR
}

enum ExamSelectionMode {
  NAO_SEI
  SELECIONAR
  ANEXAR_FUTURO
}

enum PreReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_RETORNO
  CONVERTIDO
  CANCELADO
  DUPLICADO
}

enum ContactMessageStatus {
  NOVO
  EM_ANALISE
  RESPONDIDO
  ARQUIVADO
}

enum DocumentType {
  ASO
  PCMSO
  PGR
  LTCAT
  PPP
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  RESULTADO_EXAME
  GUIA_ENCAMINHAMENTO
  CONTRATO
  PROPOSTA_ORCAMENTO
  DOCUMENTO_ADMINISTRATIVO
  OUTRO
  LAUDO
  PROPOSTA
  ENCAMINHAMENTO
}

enum DocumentStatus {
  PENDENTE
  EM_EMISSAO
  DISPONIVEL
  ENVIADO
  VENCIDO
  ARQUIVADO
  CANCELADO
  EM_ELABORACAO
  EM_DIA
  CONCLUIDO
  ENTREGUE
}

enum DocumentHistoryAction {
  CREATED
  FILE_ATTACHED
  FILE_REPLACED
  STATUS_CHANGED
  DOWNLOADED
  VIEWED
  SENT
  ARCHIVED
  PORTAL_ENABLED
  PORTAL_DISABLED
  DELETED
}

enum DocumentAccessAction {
  VIEW
  DOWNLOAD
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  passwordHash   String
  role           UserRole   @default(READ_ONLY)
  status         UserStatus @default(ACTIVE)
  clinicId       String?
  clinic         Clinic?    @relation(fields: [clinicId], references: [id])
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignedReferrals Referral[] @relation("AssignedReferrals")
  referralStatusChanges ReferralStatusHistory[]
  referralDocumentsUploaded ReferralDocument[]
  assignedPreReferrals PublicReferralRequest[] @relation("AssignedPreReferrals")
  preReferralHistory PreReferralHistory[]
  professionalAppointments Appointment[] @relation("AppointmentProfessional")
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  appointmentHistory AppointmentHistory[]
  companyContacts CompanyContact[]
  companyHistory CompanyHistory[]
  patientHistory PatientHistory[]
  examHistory    ExamHistory[]
  assignedLeads  Lead[]              @relation("AssignedLeads")
  createdQuotes  Quote[]             @relation("QuoteCreatedBy")
  commercialHistory CommercialHistory[]
  commercialNotes   CommercialNote[]
  uploadedDocuments Document[]          @relation("DocumentUploadedBy")
  documentHistory   DocumentHistory[]
  documentAccessLogs DocumentAccessLog[]
  auditLogs      AuditLog[]
  notifications  Notification[]
}

model Company {
  id                String               @id @default(cuid())
  clinicId          String?
  clinic            Clinic?              @relation(fields: [clinicId], references: [id])
  legalName         String
  tradeName         String?
  cnpj              String               @unique
  stateRegistration String?
  size              CompanySize?
  segment           String?
  email             String?
  phone             String?
  whatsapp          String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  responsibleName   String?
  responsibleRole   String?
  contractType      CompanyContractType?
  portalEnabled     Boolean              @default(false)
  status            CompanyStatus        @default(ATIVA)
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  patients          Patient[]
  referrals         Referral[]
  documents         Document[]
  users             User[]
  appointments      Appointment[]
  leads             Lead[]
  quotes            Quote[]
  contacts          CompanyContact[]
  history           CompanyHistory[]
}

model CompanyContact {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type              CompanyContactType
  title             String?
  notes             String
  performedByUserId String?
  performedBy       User?              @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime           @default(now())
}

model CompanyHistory {
  id                String               @id @default(cuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action            CompanyHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?                @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Patient {
  id               String        @id @default(cuid())
  clinicId         String?
  clinic           Clinic?       @relation(fields: [clinicId], references: [id])
  fullName         String
  cpf              String        @unique
  rg               String?
  birthDate        DateTime?
  gender           String?
  phone            String?
  email            String?
  jobTitle         String?
  department       String?
  admissionDate    DateTime?
  nextPeriodicDate DateTime?
  status           PatientStatus @default(ATIVO)
  notes            String?
  companyId        String?
  company          Company?      @relation(fields: [companyId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  referrals        Referral[]
  documents        Document[]
  appointments     Appointment[]
  history          PatientHistory[]
}

model PatientHistory {
  id                String               @id @default(cuid())
  patientId         String
  patient           Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  action            PatientHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?                @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Exam {
  id                         String              @id @default(cuid())
  clinicId                   String?
  clinic                     Clinic?             @relation(fields: [clinicId], references: [id])
  name                       String
  slug                       String              @unique
  category                   ExamCategory
  shortDescription           String?
  preparationType            ExamPreparationType @default(SEM_PREPARO)
  preparationBefore          String?
  instructionsOnDay          String?
  averageDeadline            String?
  deadlineType               ExamDeadlineType?
  observations               String?
  whenToNotifyClinic         String?
  requiresAppointment        Boolean             @default(false)
  requiresProfessional       Boolean             @default(false)
  requiresAttachment         Boolean             @default(false)
  showOnWebsite              Boolean             @default(true)
  availableOnPublicForm      Boolean             @default(true)
  availableOnCompanyPortal   Boolean             @default(true)
  displayOrder               Int?
  internalTags               String?
  status                     ExamStatus          @default(ATIVO)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  referralExams              ReferralExam[]
  appointmentExams           AppointmentExam[]
  history                    ExamHistory[]
  documents                  Document[]
}

model ExamHistory {
  id                String            @id @default(cuid())
  examId            String
  exam              Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  action            ExamHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?             @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime          @default(now())
}

model Referral {
  id                       String           @id @default(cuid())
  clinicId                 String?
  clinic                   Clinic?          @relation(fields: [clinicId], references: [id])
  protocol                 String           @unique
  companyId                String
  company                  Company          @relation(fields: [companyId], references: [id])
  patientId                String
  patient                  Patient          @relation(fields: [patientId], references: [id])
  clinicalExamType         ClinicalExamType
  status                   ReferralStatus   @default(NOVO)
  externalSystemReference  String?
  requestedDate            DateTime         @default(now())
  scheduledAt       DateTime?
  authorizerName    String?
  companyPhone      String?
  companyEmail      String?
  internalNotes     String?
  consentAccepted   Boolean          @default(false)
  assignedToId      String?
  assignedTo        User?            @relation("AssignedReferrals", fields: [assignedToId], references: [id])
  source            ReferralSource   @default(SITE)
  preReferralId     String?          @unique
  preReferral       PublicReferralRequest? @relation(fields: [preReferralId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exams             ReferralExam[]
  appointments      Appointment[]
  documents         Document[]
  referralDocuments ReferralDocument[]
  statusHistory     ReferralStatusHistory[]
}

model ReferralStatusHistory {
  id          String          @id @default(cuid())
  referralId  String
  referral    Referral        @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromStatus  ReferralStatus?
  toStatus    ReferralStatus
  notes       String?
  changedById String?
  changedBy   User?           @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())
}

model ReferralDocument {
  id           String              @id @default(cuid())
  referralId   String
  referral     Referral            @relation(fields: [referralId], references: [id], onDelete: Cascade)
  type         ReferralDocumentType @default(OUTRO)
  fileName     String
  fileUrl      String
  uploadedById String?
  uploadedBy   User?               @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime            @default(now())
}

model ReferralExam {
  id                String            @id @default(cuid())
  referralId        String
  referral          Referral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  examId            String?
  exam              Exam?             @relation(fields: [examId], references: [id])
  examName          String
  category          ExamCategory
  status            ReferralExamStatus @default(PENDENTE)
  resultAvailableAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
}

model Appointment {
  id               String            @id @default(cuid())
  clinicId         String?
  clinic           Clinic?           @relation(fields: [clinicId], references: [id])
  title            String
  protocol         String?
  scheduledAt      DateTime
  endAt            DateTime?
  status           AppointmentStatus @default(AGENDADO)
  clinicalExamType ClinicalExamType?
  type             String?
  notes            String?
  internalNotes    String?
  attendanceNotes  String?
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  patientId        String?
  patient          Patient?          @relation(fields: [patientId], references: [id])
  referralId       String?
  referral         Referral?         @relation(fields: [referralId], references: [id])
  professionalId   String?
  professional     User?             @relation("AppointmentProfessional", fields: [professionalId], references: [id])
  roomName         String?
  createdByUserId  String?
  createdBy        User?             @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  exams            AppointmentExam[]
  history          AppointmentHistory[]
}

model AppointmentExam {
  id            String             @id @default(cuid())
  appointmentId String
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam                 @relation(fields: [examId], references: [id])
  status        ReferralExamStatus   @default(PENDENTE)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @default(now()) @updatedAt

  @@unique([appointmentId, examId])
}

model AppointmentHistory {
  id                String                   @id @default(cuid())
  appointmentId     String
  appointment       Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  action            AppointmentHistoryAction
  fromStatus        AppointmentStatus?
  toStatus          AppointmentStatus?
  notes             String?
  performedByUserId String?
  performedBy       User?                    @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime                 @default(now())
}

model Lead {
  id                String     @id @default(cuid())
  clinicId          String?
  clinic            Clinic?    @relation(fields: [clinicId], references: [id])
  type              LeadType   @default(ORCAMENTO)
  status            LeadStatus @default(NOVO)
  quoteNumber       String?
  name              String
  email             String?
  phone             String?
  companyName       String?
  serviceTitle      String?
  serviceInterest   String?
  message           String?
  estimatedValue    Float?
  validUntil        DateTime?
  notes             String?
  source            String     @default("site")
  sourcePage        String?
  interestType      String?
  companyId         String?
  company           Company?   @relation(fields: [companyId], references: [id])
  contactMessageId  String?
  assignedToUserId  String?
  assignedTo        User?      @relation("AssignedLeads", fields: [assignedToUserId], references: [id])
  convertedQuoteId  String?    @unique
  convertedQuote    Quote?     @relation("LeadConvertedQuote", fields: [convertedQuoteId], references: [id])
  sourcedQuotes     Quote[]    @relation("QuoteSourceLead")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Quote {
  id                String      @id @default(cuid())
  clinicId          String?
  clinic            Clinic?     @relation(fields: [clinicId], references: [id])
  quoteNumber       String      @unique
  companyId         String?
  company           Company?    @relation(fields: [companyId], references: [id])
  companyName       String
  responsibleName   String?
  phone             String?
  email             String?
  cnpj              String?
  city              String?
  state             String?
  status            QuoteStatus @default(RASCUNHO)
  totalAmount       Float?
  validUntil        DateTime?
  paymentTerms      String?
  internalNotes     String?
  clientNotes       String?
  rejectReason      QuoteRejectReason?
  rejectNotes       String?
  sourceLeadId      String?
  sourceLead        Lead?       @relation("QuoteSourceLead", fields: [sourceLeadId], references: [id])
  convertedFromLead Lead?       @relation("LeadConvertedQuote")
  createdByUserId   String
  createdBy         User        @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id])
  items             QuoteItem[]
  documents         Document[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceName String
  category    String?
  quantity    Int      @default(1)
  unitPrice   Float?
  totalPrice  Float?
  notes       String?
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommercialHistory {
  id                String                  @id @default(cuid())
  entityType        CommercialEntityType
  entityId          String
  action            CommercialHistoryAction
  fromStatus        String?
  toStatus          String?
  notes             String?
  performedByUserId String?
  performedBy       User?                   @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime                @default(now())
}

model CommercialNote {
  id                String               @id @default(cuid())
  entityType        CommercialEntityType
  entityId          String
  content           String
  createdByUserId   String
  createdBy         User                 @relation(fields: [createdByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Document {
  id                  String         @id @default(cuid())
  clinicId            String?
  clinic              Clinic?        @relation(fields: [clinicId], references: [id])
  title               String
  type                DocumentType
  status              DocumentStatus @default(PENDENTE)
  fileName            String?
  fileUrl             String?
  fileMimeType        String?
  fileSize            Int?
  companyId           String?
  company             Company?       @relation(fields: [companyId], references: [id])
  patientId           String?
  patient             Patient?       @relation(fields: [patientId], references: [id])
  referralId          String?
  referral            Referral?      @relation(fields: [referralId], references: [id])
  examId              String?
  exam                Exam?          @relation(fields: [examId], references: [id])
  quoteId             String?
  quote               Quote?         @relation(fields: [quoteId], references: [id])
  issuedAt            DateTime?
  validUntil          DateTime?
  sensitive           Boolean        @default(false)
  availableOnPortal   Boolean        @default(false)
  uploadedByUserId    String?
  uploadedBy          User?          @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id])
  asoClinicalType     ClinicalExamType?
  asoExamDate         DateTime?
  asoProfessionalName String?
  notes               String?
  clientNotes         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  history             DocumentHistory[]
  accessLogs          DocumentAccessLog[]
}

model DocumentHistory {
  id                String                @id @default(cuid())
  documentId        String
  document          Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action            DocumentHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?                 @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime              @default(now())
}

model DocumentAccessLog {
  id         String               @id @default(cuid())
  documentId String
  document   Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  action     DocumentAccessAction
  ipAddress  String?
  createdAt  DateTime             @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PublicReferralRequest {
  id                  String                      @id @default(cuid())
  clinicId            String?
  clinic              Clinic?                     @relation(fields: [clinicId], references: [id])
  protocol            String                      @unique
  companyName         String
  companyDocument     String?
  responsibleName     String
  whatsapp            String
  email               String?
  employeeName        String
  employeeDocument    String?
  employeeRole        String
  clinicalExamType    PreReferralClinicalExamType
  examSelectionMode   ExamSelectionMode
  selectedExams       String[]
  notes               String?
  consentAccepted     Boolean                     @default(false)
  status              PreReferralStatus           @default(NOVO)
  source              String                      @default("site_pre_referral")
  assignedToId        String?
  assignedTo          User?                       @relation("AssignedPreReferrals", fields: [assignedToId], references: [id])
  convertedReferralId String?
  referral            Referral?
  history             PreReferralHistory[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
}

model PreReferralHistory {
  id            String                @id @default(cuid())
  preReferralId String
  preReferral   PublicReferralRequest @relation(fields: [preReferralId], references: [id], onDelete: Cascade)
  action        String
  fromStatus    PreReferralStatus?
  toStatus      PreReferralStatus?
  notes         String?
  performedById String?
  performedBy   User?                 @relation(fields: [performedById], references: [id])
  createdAt     DateTime              @default(now())
}

model ContactMessage {
  id              String                @id @default(cuid())
  clinicId        String?
  clinic          Clinic?               @relation(fields: [clinicId], references: [id])
  name            String
  email           String?
  phone           String
  company         String?
  subject         String
  message         String
  consentAccepted Boolean               @default(false)
  source          String                @default("site_contato")
  sourcePage      String?
  serviceInterest String?
  status          ContactMessageStatus  @default(NOVO)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}
