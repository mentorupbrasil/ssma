generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECEPCAO
  MEDICO
  TECNICO
  FINANCEIRO
  EMPRESA
  VISUALIZADOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum PatientStatus {
  ACTIVE
  INACTIVE
}

enum ExamCategory {
  CLINICO
  COMPLEMENTAR
  LABORATORIAL
  OUTRO
}

enum ClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  MUDANCA_FUNCAO
  RETORNO_TRABALHO
}

enum ReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_AGENDAMENTO
  AGENDADO
  EM_ATENDIMENTO
  CONCLUIDO
  CANCELADO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  REALIZADO
  FALTOU
  CANCELADO
}

enum LeadStatus {
  NOVO
  EM_CONTATO
  PROPOSTA_ENVIADA
  FECHADO
  PERDIDO
}

enum LeadType {
  ORCAMENTO
  CONTATO
  GERAL
}

enum PreReferralClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  RETORNO_TRABALHO
  MUDANCA_FUNCAO
  NAO_SEI_INFORMAR
}

enum ExamSelectionMode {
  NAO_SEI
  SELECIONAR
  ANEXAR_FUTURO
}

enum PreReferralStatus {
  NOVO
  EM_ANALISE
  CONVERTIDO
  CANCELADO
}

enum DocumentType {
  ASO
  PCMSO
  LTCAT
  PPP
  LAUDO
  ENCAMINHAMENTO
  OUTRO
}

enum DocumentStatus {
  PENDENTE
  EM_ELABORACAO
  CONCLUIDO
  ENTREGUE
  CANCELADO
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  passwordHash   String
  role           UserRole   @default(VISUALIZADOR)
  status         UserStatus @default(ACTIVE)
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignedReferrals Referral[] @relation("AssignedReferrals")
  auditLogs      AuditLog[]
  notifications  Notification[]
}

model Company {
  id              String        @id @default(cuid())
  legalName       String
  tradeName       String?
  cnpj            String        @unique
  email           String?
  phone           String?
  whatsapp        String?
  address         String?
  city            String?
  state           String?
  responsibleName String?
  status          CompanyStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patients        Patient[]
  referrals       Referral[]
  documents       Document[]
  users           User[]
  appointments    Appointment[]
  leads           Lead[]
}

model Patient {
  id          String        @id @default(cuid())
  fullName    String
  cpf         String        @unique
  rg          String?
  birthDate   DateTime?
  gender      String?
  phone       String?
  email       String?
  jobTitle    String?
  department  String?
  status      PatientStatus @default(ACTIVE)
  notes       String?
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  referrals   Referral[]
  documents   Document[]
  appointments Appointment[]
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  category     ExamCategory
  preparation  String?
  deliveryTime String?
  notes        String?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  referralExams ReferralExam[]
}

model Referral {
  id                String           @id @default(cuid())
  protocol          String           @unique
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  clinicalExamType  ClinicalExamType
  status            ReferralStatus   @default(NOVO)
  authorizerName    String?
  companyPhone      String?
  companyEmail      String?
  internalNotes     String?
  consentAccepted   Boolean          @default(false)
  assignedToId      String?
  assignedTo        User?            @relation("AssignedReferrals", fields: [assignedToId], references: [id])
  source            String           @default("online")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exams             ReferralExam[]
  appointments      Appointment[]
  documents         Document[]
}

model ReferralExam {
  id         String   @id @default(cuid())
  referralId String
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  examId     String?
  exam       Exam?    @relation(fields: [examId], references: [id])
  examName   String
  category   ExamCategory
  createdAt  DateTime @default(now())
}

model Appointment {
  id          String            @id @default(cuid())
  title       String
  scheduledAt DateTime
  status      AppointmentStatus @default(AGENDADO)
  type        String?
  notes       String?
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  patientId   String?
  patient     Patient?          @relation(fields: [patientId], references: [id])
  referralId  String?
  referral    Referral?         @relation(fields: [referralId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Lead {
  id            String     @id @default(cuid())
  type          LeadType   @default(ORCAMENTO)
  status        LeadStatus @default(NOVO)
  name          String
  email         String?
  phone         String?
  companyName   String?
  message       String?
  estimatedValue Float?
  notes         String?
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Document {
  id         String         @id @default(cuid())
  title      String
  type       DocumentType
  status     DocumentStatus @default(PENDENTE)
  fileUrl    String?
  notes      String?
  companyId  String?
  company    Company?       @relation(fields: [companyId], references: [id])
  patientId  String?
  patient    Patient?       @relation(fields: [patientId], references: [id])
  referralId String?
  referral   Referral?      @relation(fields: [referralId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PublicReferralRequest {
  id                String                      @id @default(cuid())
  protocol          String                      @unique
  companyName       String
  companyDocument   String?
  responsibleName   String
  whatsapp          String
  email             String?
  employeeName      String
  employeeDocument  String?
  employeeRole      String
  clinicalExamType  PreReferralClinicalExamType
  examSelectionMode ExamSelectionMode
  selectedExams     String[]
  notes             String?
  consentAccepted   Boolean                     @default(false)
  status            PreReferralStatus           @default(NOVO)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
}
