generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CLINIC_ADMIN
  RECEPTION
  COMMERCIAL
  FINANCIAL
  SST_TECHNICIAN
  HEALTH_PROFESSIONAL
  COMPANY_HR
  READ_ONLY
  ADMIN
  RECEPCAO
  MEDICO
  TECNICO
  FINANCEIRO
  EMPRESA
  VISUALIZADOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClinicStatus {
  ATIVA
  TRIAL
  SUSPENSA
  CANCELADA
  BLOQUEADA
}

enum ClinicPlan {
  TRIAL
  BASICO
  PROFISSIONAL
  ENTERPRISE
}

model Clinic {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  status          ClinicStatus @default(ATIVA)
  plan            ClinicPlan   @default(TRIAL)
  responsibleName String?
  email           String?
  whatsapp        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  users           User[]
  companies       Company[]
  patients        Patient[]
  referrals       Referral[]
  preReferrals    PublicReferralRequest[]
  documents       Document[]
  leads           Lead[]
  quotes          Quote[]
  appointments    Appointment[]
  exams           Exam[]
  auditLogs       AuditLog[]
  contactMessages ContactMessage[]
  tasks           Task[]
  tickets         Ticket[]
  financialEntries FinancialEntry[]
  monthlyClosings MonthlyClosing[]
  blogPosts       BlogPost[]
  settings        Setting[]
  priceListItems  PriceListItem[]
  productionImports ProductionImport[]
  sstDrafts       SstDraft[]
}

enum CompanyStatus {
  ATIVA
  INATIVA
  PENDENTE
  BLOQUEADA
}

enum CompanySize {
  PEQUENA
  MEDIA
  GRANDE
}

enum CompanyContractType {
  AVULSO
  MENSAL
  ANUAL
  EM_NEGOCIACAO
}

enum CompanyContactType {
  SITE
  WHATSAPP
  TELEFONE
  EMAIL
  VISITA
  COMERCIAL
  OUTRO
}

enum CompanyHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  EMPLOYEE_ADDED
  REFERRAL_CREATED
  QUOTE_SENT
  DOCUMENT_ATTACHED
  PORTAL_ENABLED
  PORTAL_DISABLED
  USER_CREATED
  CONTACT_ADDED
}

enum PatientStatus {
  ATIVO
  INATIVO
  AFASTADO
  DESLIGADO
  PENDENTE
}

enum PatientHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  REFERRAL_CREATED
  APPOINTMENT_SCHEDULED
  ATTENDANCE_STARTED
  ATTENDANCE_COMPLETED
  DOCUMENT_ATTACHED
  ASO_AVAILABLE
  COMPANY_LINKED
}

enum ExamCategory {
  CLINICO_OCUPACIONAL
  COMPLEMENTAR
  LABORATORIAL
  IMAGEM
  TOXICOLOGICO
  AVALIACAO_ESPECIALIZADA
  OUTRO
}

enum ExamStatus {
  ATIVO
  INATIVO
  EM_REVISAO
}

enum ExamPreparationType {
  SEM_PREPARO
  PREPARO_NECESSARIO
  JEJUM_NECESSARIO
  ATENCAO_ESPECIAL
  VERIFICAR_EXAME
  ORIENTACAO_ESPECIFICA
}

enum ExamDeadlineType {
  NO_DIA
  DIAS_UTEIS
  CONFORME_AGENDAMENTO
  CONFORME_LABORATORIO
}

enum ExamHistoryAction {
  CREATED
  UPDATED
  PREPARATION_CHANGED
  DEADLINE_CHANGED
  STATUS_CHANGED
  PUBLISHED
  UNPUBLISHED
  DUPLICATED
}

enum ClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  MUDANCA_FUNCAO
  RETORNO_TRABALHO
}

enum ReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_AGENDAMENTO
  AGENDADO
  EM_ATENDIMENTO
  AGUARDANDO_RESULTADO
  AGUARDANDO_DOCUMENTO
  ASO_DISPONIVEL
  CONCLUIDO
  CANCELADO
}

enum ReferralSource {
  PORTAL
  ADMIN
  PRE_REFERRAL
  SITE
}

enum ReferralExamStatus {
  PENDENTE
  AGENDADO
  REALIZADO
  RESULTADO_DISPONIVEL
  CANCELADO
}

enum ReferralDocumentType {
  ASO
  GUIA
  LAUDO
  RESULTADO
  OUTRO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  FALTOU
  REAGENDADO
  CANCELADO
}

enum AppointmentHistoryAction {
  CREATED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  ATTENDANCE_STARTED
  COMPLETED
  NOTE_ADDED
  STATUS_CHANGED
}

enum LeadStatus {
  NOVO
  EM_ANALISE
  EM_CONTATO
  AGUARDANDO_RETORNO
  CONVERTIDO_ORCAMENTO
  PROPOSTA_ENVIADA
  FECHADO
  PERDIDO
  EXPIRADO
  ARQUIVADO
}

enum CommercialStage {
  NOVO_LEAD
  CONTATO_REALIZADO
  QUALIFICACAO
  PROPOSTA_ENVIADA
  EM_NEGOCIACAO
  AGUARDANDO_RETORNO
  GANHO
  PERDIDO
}

enum CommercialFollowUpStatus {
  PENDENTE
  REALIZADO
  CANCELADO
}

enum QuoteStatus {
  RASCUNHO
  EM_ANALISE
  ENVIADO
  AGUARDANDO_RESPOSTA
  APROVADO
  RECUSADO
  EXPIRADO
  CANCELADO
}

enum CommercialEntityType {
  LEAD
  QUOTE
  CONTACT
}

enum CommercialHistoryAction {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  WHATSAPP_OPENED
  EMAIL_SENT
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
  QUOTE_DUPLICATED
  COMPANY_LINKED
  REFERRAL_CREATED
  PORTAL_ENABLED
  ARCHIVED
}

enum QuoteRejectReason {
  VALOR
  SEM_RESPOSTA
  OUTRO_FORNECEDOR
  SEM_INTERESSE
  OUTRO
}

enum LeadType {
  ORCAMENTO
  CONTATO
  GERAL
}

enum PreReferralClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  RETORNO_TRABALHO
  MUDANCA_FUNCAO
  NAO_SEI_INFORMAR
}

enum ExamSelectionMode {
  NAO_SEI
  SELECIONAR
  ANEXAR_FUTURO
}

enum PreReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_RETORNO
  CONVERTIDO
  CANCELADO
  DUPLICADO
}

enum ContactMessageStatus {
  NOVO
  EM_ANALISE
  RESPONDIDO
  ARQUIVADO
}

enum DocumentType {
  ASO
  PCMSO
  PGR
  LTCAT
  PPP
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  RESULTADO_EXAME
  GUIA_ENCAMINHAMENTO
  CONTRATO
  PROPOSTA_ORCAMENTO
  DOCUMENTO_ADMINISTRATIVO
  OUTRO
  LAUDO
  PROPOSTA
  ENCAMINHAMENTO
}

enum DocumentStatus {
  PENDENTE
  EM_EMISSAO
  DISPONIVEL
  ENVIADO
  VENCIDO
  ARQUIVADO
  CANCELADO
  EM_ELABORACAO
  EM_DIA
  CONCLUIDO
  ENTREGUE
}

enum DocumentHistoryAction {
  CREATED
  FILE_ATTACHED
  FILE_REPLACED
  STATUS_CHANGED
  DOWNLOADED
  VIEWED
  SENT
  ARCHIVED
  PORTAL_ENABLED
  PORTAL_DISABLED
  DELETED
}

enum DocumentAccessAction {
  VIEW
  DOWNLOAD
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  passwordHash   String
  role           UserRole   @default(READ_ONLY)
  status         UserStatus @default(ACTIVE)
  clinicId       String?
  clinic         Clinic?    @relation(fields: [clinicId], references: [id])
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  lastAccessAt   DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignedReferrals Referral[] @relation("AssignedReferrals")
  referralStatusChanges ReferralStatusHistory[]
  referralDocumentsUploaded ReferralDocument[]
  assignedPreReferrals PublicReferralRequest[] @relation("AssignedPreReferrals")
  preReferralHistory PreReferralHistory[]
  professionalAppointments Appointment[] @relation("AppointmentProfessional")
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  appointmentHistory AppointmentHistory[]
  companyContacts CompanyContact[]
  companyHistory CompanyHistory[]
  patientHistory PatientHistory[]
  examHistory    ExamHistory[]
  assignedLeads  Lead[]              @relation("AssignedLeads")
  assignedFollowUps CommercialFollowUp[] @relation("FollowUpAssignee")
  createdFollowUps  CommercialFollowUp[] @relation("FollowUpCreatedBy")
  createdQuotes  Quote[]             @relation("QuoteCreatedBy")
  commercialHistory CommercialHistory[]
  commercialNotes   CommercialNote[]
  uploadedDocuments Document[]          @relation("DocumentUploadedBy")
  documentHistory   DocumentHistory[]
  documentAccessLogs DocumentAccessLog[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  assignedTasks  Task[]              @relation("AssignedTasks")
  createdTasks   Task[]              @relation("CreatedTasks")
  createdTickets Ticket[]            @relation("TicketCreatedBy")
  assignedTickets Ticket[]           @relation("TicketAssignedTo")
  ticketComments  TicketComment[]    @relation("TicketComments")
  createdClosings MonthlyClosing[]   @relation("ClosingCreatedBy")
  productionImports ProductionImport[] @relation("ProductionImportCreatedBy")
  priceListHistory  PriceListHistory[] @relation("PriceListChangedBy")
  sstDraftsCreated   SstDraft[]         @relation("SstDraftCreatedBy")
  sstDraftsResponsible SstDraft[]       @relation("SstDraftResponsible")
  sstDraftsReviewed  SstDraft[]         @relation("SstDraftReviewedBy")
  sstDraftsApproved  SstDraft[]         @relation("SstDraftApprovedBy")
  sstDraftVersions   SstDraftVersion[]  @relation("SstDraftVersionAuthor")
  sstDraftComments   SstDraftComment[]  @relation("SstDraftCommentAuthor")
}

model Company {
  id                String               @id @default(cuid())
  clinicId          String?
  clinic            Clinic?              @relation(fields: [clinicId], references: [id])
  legalName         String
  tradeName         String?
  cnpj              String               @unique
  stateRegistration String?
  size              CompanySize?
  segment           String?
  email             String?
  phone             String?
  whatsapp          String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  responsibleName   String?
  responsibleRole   String?
  contractType      CompanyContractType?
  portalEnabled     Boolean              @default(false)
  status            CompanyStatus        @default(ATIVA)
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  patients          Patient[]
  referrals         Referral[]
  documents         Document[]
  users             User[]
  appointments      Appointment[]
  leads             Lead[]
  quotes            Quote[]
  contacts          CompanyContact[]
  history           CompanyHistory[]
  tasks             Task[]
  tickets           Ticket[]
  financialEntries  FinancialEntry[]
  monthlyClosings   MonthlyClosing[]
  priceListItems    PriceListItem[]
  productionImportRows ProductionImportRow[]
  closingLineItems  ClosingLineItem[]
  sstDrafts         SstDraft[]
}

model CompanyContact {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type              CompanyContactType
  title             String?
  notes             String
  performedByUserId String?
  performedBy       User?              @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime           @default(now())
}

model CompanyHistory {
  id                String               @id @default(cuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action            CompanyHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?                @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Patient {
  id               String        @id @default(cuid())
  clinicId         String?
  clinic           Clinic?       @relation(fields: [clinicId], references: [id])
  fullName         String
  cpf              String        @unique
  rg               String?
  birthDate        DateTime?
  gender           String?
  phone            String?
  email            String?
  jobTitle         String?
  department       String?
  admissionDate    DateTime?
  nextPeriodicDate DateTime?
  status           PatientStatus @default(ATIVO)
  notes            String?
  companyId        String?
  company          Company?      @relation(fields: [companyId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  referrals        Referral[]
  documents        Document[]
  appointments     Appointment[]
  history          PatientHistory[]
}

model PatientHistory {
  id                String               @id @default(cuid())
  patientId         String
  patient           Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  action            PatientHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?                @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Exam {
  id                         String              @id @default(cuid())
  clinicId                   String?
  clinic                     Clinic?             @relation(fields: [clinicId], references: [id])
  name                       String
  slug                       String              @unique
  category                   ExamCategory
  shortDescription           String?
  preparationType            ExamPreparationType @default(SEM_PREPARO)
  preparationBefore          String?
  instructionsOnDay          String?
  averageDeadline            String?
  deadlineType               ExamDeadlineType?
  observations               String?
  whenToNotifyClinic         String?
  requiresAppointment        Boolean             @default(false)
  requiresProfessional       Boolean             @default(false)
  requiresAttachment         Boolean             @default(false)
  showOnWebsite              Boolean             @default(true)
  availableOnPublicForm      Boolean             @default(true)
  availableOnCompanyPortal   Boolean             @default(true)
  displayOrder               Int?
  internalTags               String?
  status                     ExamStatus          @default(ATIVO)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  referralExams              ReferralExam[]
  appointmentExams           AppointmentExam[]
  history                    ExamHistory[]
  documents                  Document[]
  priceListItems             PriceListItem[]
}

model ExamHistory {
  id                String            @id @default(cuid())
  examId            String
  exam              Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  action            ExamHistoryAction
  notes             String?
  performedByUserId String?
  performedBy       User?             @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime          @default(now())
}

model Referral {
  id                       String           @id @default(cuid())
  clinicId                 String?
  clinic                   Clinic?          @relation(fields: [clinicId], references: [id])
  protocol                 String           @unique
  companyId                String
  company                  Company          @relation(fields: [companyId], references: [id])
  patientId                String
  patient                  Patient          @relation(fields: [patientId], references: [id])
  clinicalExamType         ClinicalExamType
  status                   ReferralStatus   @default(NOVO)
  externalSystemReference  String?
  requestedDate            DateTime         @default(now())
  scheduledAt       DateTime?
  authorizerName    String?
  companyPhone      String?
  companyEmail      String?
  internalNotes     String?
  consentAccepted   Boolean          @default(false)
  assignedToId      String?
  assignedTo        User?            @relation("AssignedReferrals", fields: [assignedToId], references: [id])
  source            ReferralSource   @default(SITE)
  preReferralId     String?          @unique
  preReferral       PublicReferralRequest? @relation(fields: [preReferralId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exams             ReferralExam[]
  appointments      Appointment[]
  documents         Document[]
  referralDocuments ReferralDocument[]
  statusHistory     ReferralStatusHistory[]
}

model ReferralStatusHistory {
  id          String          @id @default(cuid())
  referralId  String
  referral    Referral        @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromStatus  ReferralStatus?
  toStatus    ReferralStatus
  notes       String?
  changedById String?
  changedBy   User?           @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())
}

model ReferralDocument {
  id           String              @id @default(cuid())
  referralId   String
  referral     Referral            @relation(fields: [referralId], references: [id], onDelete: Cascade)
  type         ReferralDocumentType @default(OUTRO)
  fileName     String
  fileUrl      String
  uploadedById String?
  uploadedBy   User?               @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime            @default(now())
}

model ReferralExam {
  id                String            @id @default(cuid())
  referralId        String
  referral          Referral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  examId            String?
  exam              Exam?             @relation(fields: [examId], references: [id])
  examName          String
  category          ExamCategory
  status            ReferralExamStatus @default(PENDENTE)
  resultAvailableAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
}

model Appointment {
  id               String            @id @default(cuid())
  clinicId         String?
  clinic           Clinic?           @relation(fields: [clinicId], references: [id])
  title            String
  protocol         String?
  scheduledAt      DateTime
  endAt            DateTime?
  status           AppointmentStatus @default(AGENDADO)
  clinicalExamType ClinicalExamType?
  type             String?
  notes            String?
  internalNotes    String?
  attendanceNotes  String?
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  patientId        String?
  patient          Patient?          @relation(fields: [patientId], references: [id])
  referralId       String?
  referral         Referral?         @relation(fields: [referralId], references: [id])
  professionalId   String?
  professional     User?             @relation("AppointmentProfessional", fields: [professionalId], references: [id])
  roomName         String?
  createdByUserId  String?
  createdBy        User?             @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  exams            AppointmentExam[]
  history          AppointmentHistory[]
}

model AppointmentExam {
  id            String             @id @default(cuid())
  appointmentId String
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam                 @relation(fields: [examId], references: [id])
  status        ReferralExamStatus   @default(PENDENTE)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @default(now()) @updatedAt

  @@unique([appointmentId, examId])
}

model AppointmentHistory {
  id                String                   @id @default(cuid())
  appointmentId     String
  appointment       Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  action            AppointmentHistoryAction
  fromStatus        AppointmentStatus?
  toStatus          AppointmentStatus?
  notes             String?
  performedByUserId String?
  performedBy       User?                    @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime                 @default(now())
}

model Lead {
  id                String     @id @default(cuid())
  clinicId          String?
  clinic            Clinic?    @relation(fields: [clinicId], references: [id])
  type              LeadType   @default(ORCAMENTO)
  status            LeadStatus @default(NOVO)
  stage             CommercialStage @default(NOVO_LEAD)
  quoteNumber       String?
  name              String
  email             String?
  phone             String?
  companyName       String?
  serviceTitle      String?
  serviceInterest   String?
  message           String?
  estimatedValue    Float?
  validUntil        DateTime?
  notes             String?
  source            String     @default("site")
  sourcePage        String?
  interestType      String?
  city              String?
  cnpj              String?
  estimatedEmployees Int?
  nextFollowUpAt    DateTime?
  followUpAction    String?
  lastContactAt     DateTime?
  lostReason        String?
  companyId         String?
  company           Company?   @relation(fields: [companyId], references: [id])
  contactMessageId  String?
  assignedToUserId  String?
  assignedTo        User?      @relation("AssignedLeads", fields: [assignedToUserId], references: [id])
  convertedQuoteId  String?    @unique
  convertedQuote    Quote?     @relation("LeadConvertedQuote", fields: [convertedQuoteId], references: [id])
  sourcedQuotes     Quote[]    @relation("QuoteSourceLead")
  followUps         CommercialFollowUp[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model CommercialFollowUp {
  id                String                    @id @default(cuid())
  leadId            String
  lead              Lead                      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dueAt             DateTime
  action            String
  status            CommercialFollowUpStatus  @default(PENDENTE)
  result            String?
  notes             String?
  assignedToUserId  String?
  assignedTo        User?                     @relation("FollowUpAssignee", fields: [assignedToUserId], references: [id])
  createdByUserId   String?
  createdBy         User?                     @relation("FollowUpCreatedBy", fields: [createdByUserId], references: [id])
  completedAt       DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([dueAt, status])
  @@index([leadId])
}

model Quote {
  id                String      @id @default(cuid())
  clinicId          String?
  clinic            Clinic?     @relation(fields: [clinicId], references: [id])
  quoteNumber       String      @unique
  companyId         String?
  company           Company?    @relation(fields: [companyId], references: [id])
  companyName       String
  responsibleName   String?
  phone             String?
  email             String?
  cnpj              String?
  city              String?
  state             String?
  status            QuoteStatus @default(RASCUNHO)
  totalAmount       Float?
  validUntil        DateTime?
  paymentTerms      String?
  internalNotes     String?
  clientNotes       String?
  rejectReason      QuoteRejectReason?
  rejectNotes       String?
  sourceLeadId      String?
  sourceLead        Lead?       @relation("QuoteSourceLead", fields: [sourceLeadId], references: [id])
  convertedFromLead Lead?       @relation("LeadConvertedQuote")
  createdByUserId   String
  createdBy         User        @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id])
  items             QuoteItem[]
  documents         Document[]
  financialEntries  FinancialEntry[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceName String
  category    String?
  quantity    Int      @default(1)
  unitPrice   Float?
  totalPrice  Float?
  notes       String?
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommercialHistory {
  id                String                  @id @default(cuid())
  entityType        CommercialEntityType
  entityId          String
  action            CommercialHistoryAction
  fromStatus        String?
  toStatus          String?
  notes             String?
  performedByUserId String?
  performedBy       User?                   @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime                @default(now())
}

model CommercialNote {
  id                String               @id @default(cuid())
  entityType        CommercialEntityType
  entityId          String
  content           String
  createdByUserId   String
  createdBy         User                 @relation(fields: [createdByUserId], references: [id])
  createdAt         DateTime             @default(now())
}

model Document {
  id                  String         @id @default(cuid())
  clinicId            String?
  clinic              Clinic?        @relation(fields: [clinicId], references: [id])
  title               String
  type                DocumentType
  status              DocumentStatus @default(PENDENTE)
  fileName            String?
  fileUrl             String?
  fileMimeType        String?
  fileSize            Int?
  companyId           String?
  company             Company?       @relation(fields: [companyId], references: [id])
  patientId           String?
  patient             Patient?       @relation(fields: [patientId], references: [id])
  referralId          String?
  referral            Referral?      @relation(fields: [referralId], references: [id])
  examId              String?
  exam                Exam?          @relation(fields: [examId], references: [id])
  quoteId             String?
  quote               Quote?         @relation(fields: [quoteId], references: [id])
  issuedAt            DateTime?
  validUntil          DateTime?
  sensitive           Boolean        @default(false)
  availableOnPortal   Boolean        @default(false)
  uploadedByUserId    String?
  uploadedBy          User?          @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id])
  asoClinicalType     ClinicalExamType?
  asoExamDate         DateTime?
  asoProfessionalName String?
  notes               String?
  clientNotes         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  history             DocumentHistory[]
  accessLogs          DocumentAccessLog[]
  sstDraftsPublished  SstDraft[]
}

model DocumentHistory {
