enum PriceItemCategory {
  EXAME
  ASO
  SERVICO
  PACOTE
  LAUDO
  OUTRO
}

enum PriceChargeType {
  AVULSA
  MENSAL
  PACOTE
  CONTRATO
  CONVENIO
}

enum PriceListStatus {
  ATIVA
  INATIVA
  VENCIDA
}

enum ProductionImportStatus {
  RASCUNHO
  EM_CONFERENCIA
  COM_DIVERGENCIA
  CONFERIDO
  FECHADO
  CANCELADO
}

enum ProductionImportRowStatus {
  PENDENTE
  RECONHECIDO
  SEM_EMPRESA
  SEM_PRECO
  DUPLICADO
  DIVERGENCIA
  PRONTO
}

model PriceListItem {
  id              String            @id @default(cuid())
  clinicId        String?
  clinic          Clinic?           @relation(fields: [clinicId], references: [id])
  name            String
  code            String?
  category        PriceItemCategory @default(EXAME)
  examId          String?
  exam            Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  defaultPrice    Float
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  negotiatedPrice Float?
  chargeType      PriceChargeType   @default(AVULSA)
  validFrom       DateTime?
  validUntil      DateTime?
  status          PriceListStatus   @default(ATIVA)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  history         PriceListHistory[]
  importRows      ProductionImportRow[]

  @@index([clinicId, companyId])
  @@index([name])
}

model PriceListHistory {
  id              String        @id @default(cuid())
  priceListItemId String
  priceListItem   PriceListItem @relation(fields: [priceListItemId], references: [id], onDelete: Cascade)
  oldPrice        Float?
  newPrice        Float?
  changedByUserId String?
  changedBy       User?         @relation("PriceListChangedBy", fields: [changedByUserId], references: [id])
  notes           String?
  createdAt       DateTime      @default(now())
}

model ProductionImport {
  id               String                 @id @default(cuid())
  clinicId         String?
  clinic           Clinic?                @relation(fields: [clinicId], references: [id])
  referenceMonth   DateTime
  fileName         String?
  status           ProductionImportStatus @default(RASCUNHO)
  totalRows        Int                    @default(0)
  recognizedRows   Int                    @default(0)
  withoutCompany   Int                    @default(0)
  withoutPrice     Int                    @default(0)
  duplicates       Int                    @default(0)
  divergences      Int                    @default(0)
  importedByUserId String
  importedBy       User                   @relation("ProductionImportCreatedBy", fields: [importedByUserId], references: [id])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  rows             ProductionImportRow[]
  closings         MonthlyClosing[]
}

model ProductionImportRow {
  id                 String                    @id @default(cuid())
  importId           String
  import             ProductionImport          @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber          Int
  companyName        String?
  companyCnpj        String?
  patientName        String?
  patientCpf         String?
  serviceDate        DateTime?
  examType           String?
  complementaryExams String?
  protocol           String?
  importedValue      Float?
  matchedPrice       Float?
  status             ProductionImportRowStatus @default(PENDENTE)
  companyId          String?
  company            Company?                  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  priceListItemId    String?
  priceListItem      PriceListItem?            @relation(fields: [priceListItemId], references: [id], onDelete: SetNull)
  closingId          String?
  closing            MonthlyClosing?           @relation(fields: [closingId], references: [id], onDelete: SetNull)
  notes              String?
  createdAt          DateTime                  @default(now())

  @@index([importId, status])
}

model ClosingLineItem {
  id          String          @id @default(cuid())
  closingId   String
  closing     MonthlyClosing  @relation(fields: [closingId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  serviceName String
  patientName String?
  patientCpf  String?
  serviceDate DateTime?
  examType    String?
  quantity    Int             @default(1)
  unitPrice   Float
  totalPrice  Float
  notes       String?
  createdAt   DateTime        @default(now())
}
