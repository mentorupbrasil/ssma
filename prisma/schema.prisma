enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum TaskPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TicketStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO_CLIENTE
  RESOLVIDO
  FECHADO
}

enum TicketPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TicketScope {
  CLINIC
  SAAS
}

enum FinancialEntryType {
  RECEBER
  PAGAR
}

enum FinancialEntryStatus {
  PENDENTE
  AGUARDANDO_FATURAMENTO
  PARCIAL
  PAGO
  ATRASADO
  CANCELADO
}

enum MonthlyClosingStatus {
  RASCUNHO
  EM_REVISAO
  EM_CONFERENCIA
  COM_DIVERGENCIA
  AGUARDANDO_APROVACAO
  FECHADO
  FATURADO
  PAGO
  EM_ATRASO
  CANCELADO
}

enum FinancialEntrySource {
  FECHAMENTO
  ORCAMENTO
  AVULSO
  CONTRATO
  MANUAL
}

model Task {
  id                String       @id @default(cuid())
  clinicId          String?
  clinic            Clinic?      @relation(fields: [clinicId], references: [id])
  title             String
  description       String?
  status            TaskStatus   @default(PENDENTE)
  priority          TaskPriority @default(MEDIA)
  dueDate           DateTime?
  assignedToUserId  String?
  assignedTo        User?        @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  createdByUserId   String
  createdBy         User         @relation("CreatedTasks", fields: [createdByUserId], references: [id])
  companyId         String?
  company           Company?     @relation(fields: [companyId], references: [id])
  /// EMPRESA | COLABORADOR | FECHAMENTO | DOCUMENTO | COMERCIAL | FINANCEIRO | CHAMADO | MANUAL
  origin            String?
  linkUrl           String?
  systemGenerated   Boolean      @default(false)
  /// Chave estável para deduplicar tarefas automáticas
  sourceKey         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([clinicId, status])
  @@index([sourceKey])
}

model Ticket {
  id                String         @id @default(cuid())
  clinicId          String?
  clinic            Clinic?        @relation(fields: [clinicId], references: [id])
  scope             TicketScope    @default(CLINIC)
  protocol          String?
  subject           String
  description       String
  status            TicketStatus   @default(ABERTO)
  priority          TicketPriority @default(MEDIA)
  category          String?
  createdByUserId   String
  createdBy         User           @relation("TicketCreatedBy", fields: [createdByUserId], references: [id])
  assignedToUserId  String?
  assignedTo        User?          @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id])
  companyId         String?
  company           Company?       @relation(fields: [companyId], references: [id])
  comments          TicketComment[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([clinicId, status])
  @@index([protocol])
}

enum SstDocKind {
  PGR
  PCMSO
  LTCAT
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  ORDEM_SERVICO
  APR
  INVENTARIO_RISCOS
  RELATORIO_INSPECAO
  PLANO_ACAO
  OUTROS
}

enum SstDocStage {
  RASCUNHO
  EM_ELABORACAO
  AGUARDANDO_REVISAO
  APROVADO
  ARQUIVADO
}

enum SstDocComplexity {
  TECNICO
  SIMPLIFICADO
}

/// Rascunho de documento SST com fluxo de elaboração → revisão → aprovação.
model SstDraft {
  id                         String           @id @default(cuid())
  clinicId                   String?
  clinic                     Clinic?          @relation(fields: [clinicId], references: [id])
  companyId                  String
  company                    Company          @relation(fields: [companyId], references: [id])
  kind                       SstDocKind
  title                      String
  stage                      SstDocStage      @default(RASCUNHO)
  complexity                 SstDocComplexity
  version                    Int              @default(1)
  /// Seções preenchidas do formulário específico do tipo (JSON).
  contentJson                String           @default("{}")
  /// Snapshot do checklist de dados no momento da criação/atualização (JSON).
  checklistJson              String?
  /// Anexos: medições, laudos, evidências [{name,url,notes}].
  attachmentsJson            String           @default("[]")
  technicalResponsibleUserId String?
  technicalResponsible       User?            @relation("SstDraftResponsible", fields: [technicalResponsibleUserId], references: [id])
  createdByUserId            String
  createdBy                  User             @relation("SstDraftCreatedBy", fields: [createdByUserId], references: [id])
  reviewedByUserId           String?
  reviewedBy                 User?            @relation("SstDraftReviewedBy", fields: [reviewedByUserId], references: [id])
  approvedByUserId           String?
  approvedBy                 User?            @relation("SstDraftApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt                 DateTime?
  publishedDocumentId        String?
  publishedDocument          Document?        @relation(fields: [publishedDocumentId], references: [id])
  validUntil                 DateTime?
  notes                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  versions                   SstDraftVersion[]
  comments                   SstDraftComment[]

  @@index([clinicId, stage])
  @@index([companyId, kind])
}

model SstDraftVersion {
  id              String   @id @default(cuid())
  draftId         String
  draft           SstDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  version         Int
  contentJson     String
  stage           SstDocStage
  notes           String?
  createdByUserId String
  createdBy       User     @relation("SstDraftVersionAuthor", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([draftId, version])
}

model SstDraftComment {
  id              String   @id @default(cuid())
  draftId         String
  draft           SstDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sectionKey      String?
  content         String
  createdByUserId String
  createdBy       User     @relation("SstDraftCommentAuthor", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([draftId])
}

model TicketComment {
  id              String   @id @default(cuid())
  ticketId        String
  ticket          Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content         String
  isInternal      Boolean  @default(false)
  attachmentUrl   String?
  createdByUserId String
  createdBy       User     @relation("TicketComments", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
}

model MonthlyClosing {
  id              String               @id @default(cuid())
  clinicId        String?
  clinic          Clinic?              @relation(fields: [clinicId], references: [id])
  referenceMonth  DateTime
  status          MonthlyClosingStatus @default(RASCUNHO)
  totalAmount     Float?
  notes           String?
  companyId       String?
  company         Company?             @relation(fields: [companyId], references: [id])
  importId        String?
  productionImport ProductionImport?   @relation(fields: [importId], references: [id], onDelete: SetNull)
  importedCount   Int                  @default(0)
  withoutPriceCount Int                @default(0)
  divergenceCount Int                  @default(0)
  createdByUserId String
  createdBy       User                 @relation("ClosingCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  entries         FinancialEntry[]
  lineItems       ClosingLineItem[]
  importRows      ProductionImportRow[]
}

model FinancialEntry {
  id              String               @id @default(cuid())
  clinicId        String?
  clinic          Clinic?              @relation(fields: [clinicId], references: [id])
  type            FinancialEntryType
  source          FinancialEntrySource @default(MANUAL)
  description     String
  amount          Float
  dueDate         DateTime
  paidAt          DateTime?
  status          FinancialEntryStatus @default(PENDENTE)
  category        String?
  companyId       String?
  company         Company?             @relation(fields: [companyId], references: [id])
  closingId       String?
  closing         MonthlyClosing?      @relation(fields: [closingId], references: [id])
  quoteId         String?
  quote           Quote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  referenceMonth  DateTime?
  paymentMethod   String?
  invoiceNumber   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  clinicId    String?
  clinic      Clinic?  @relation(fields: [clinicId], references: [id])
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  coverImage  String?
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
