generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECEPCAO
  MEDICO
  TECNICO
  FINANCEIRO
  EMPRESA
  VISUALIZADOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum PatientStatus {
  ACTIVE
  INACTIVE
}

enum ExamCategory {
  CLINICO
  COMPLEMENTAR
  LABORATORIAL
  OUTRO
}

enum ClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  MUDANCA_FUNCAO
  RETORNO_TRABALHO
}

enum ReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_AGENDAMENTO
  AGENDADO
  EM_ATENDIMENTO
  AGUARDANDO_RESULTADO
  AGUARDANDO_DOCUMENTO
  ASO_DISPONIVEL
  CONCLUIDO
  CANCELADO
}

enum ReferralSource {
  PORTAL
  ADMIN
  PRE_REFERRAL
  SITE
}

enum ReferralExamStatus {
  PENDENTE
  AGENDADO
  REALIZADO
  RESULTADO_DISPONIVEL
  CANCELADO
}

enum ReferralDocumentType {
  ASO
  GUIA
  LAUDO
  RESULTADO
  OUTRO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  FALTOU
  REAGENDADO
  CANCELADO
}

enum AppointmentHistoryAction {
  CREATED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  ATTENDANCE_STARTED
  COMPLETED
  NOTE_ADDED
  STATUS_CHANGED
}

enum LeadStatus {
  NOVO
  EM_CONTATO
  PROPOSTA_ENVIADA
  FECHADO
  PERDIDO
}

enum LeadType {
  ORCAMENTO
  CONTATO
  GERAL
}

enum PreReferralClinicalExamType {
  ADMISSIONAL
  DEMISSIONAL
  PERIODICO
  RETORNO_TRABALHO
  MUDANCA_FUNCAO
  NAO_SEI_INFORMAR
}

enum ExamSelectionMode {
  NAO_SEI
  SELECIONAR
  ANEXAR_FUTURO
}

enum PreReferralStatus {
  NOVO
  EM_ANALISE
  AGUARDANDO_RETORNO
  CONVERTIDO
  CANCELADO
  DUPLICADO
}

enum ContactMessageStatus {
  NOVO
  EM_ANALISE
  RESPONDIDO
  ARQUIVADO
}

enum DocumentType {
  ASO
  PCMSO
  LTCAT
  PPP
  LAUDO
  ENCAMINHAMENTO
  OUTRO
}

enum DocumentStatus {
  PENDENTE
  EM_ELABORACAO
  CONCLUIDO
  ENTREGUE
  CANCELADO
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  passwordHash   String
  role           UserRole   @default(VISUALIZADOR)
  status         UserStatus @default(ACTIVE)
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  assignedReferrals Referral[] @relation("AssignedReferrals")
  referralStatusChanges ReferralStatusHistory[]
  referralDocumentsUploaded ReferralDocument[]
  assignedPreReferrals PublicReferralRequest[] @relation("AssignedPreReferrals")
  preReferralHistory PreReferralHistory[]
  professionalAppointments Appointment[] @relation("AppointmentProfessional")
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  appointmentHistory AppointmentHistory[]
  auditLogs      AuditLog[]
  notifications  Notification[]
}

model Company {
  id              String        @id @default(cuid())
  legalName       String
  tradeName       String?
  cnpj            String        @unique
  email           String?
  phone           String?
  whatsapp        String?
  address         String?
  city            String?
  state           String?
  responsibleName String?
  status          CompanyStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patients        Patient[]
  referrals       Referral[]
  documents       Document[]
  users           User[]
  appointments    Appointment[]
  leads           Lead[]
}

model Patient {
  id          String        @id @default(cuid())
  fullName    String
  cpf         String        @unique
  rg          String?
  birthDate   DateTime?
  gender      String?
  phone       String?
  email       String?
  jobTitle    String?
  department  String?
  status      PatientStatus @default(ACTIVE)
  notes       String?
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  referrals   Referral[]
  documents   Document[]
  appointments Appointment[]
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  category     ExamCategory
  preparation  String?
  deliveryTime String?
  notes        String?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  referralExams ReferralExam[]
  appointmentExams AppointmentExam[]
}

model Referral {
  id                String           @id @default(cuid())
  protocol          String           @unique
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  clinicalExamType  ClinicalExamType
  status            ReferralStatus   @default(NOVO)
  requestedDate     DateTime         @default(now())
  scheduledAt       DateTime?
  authorizerName    String?
  companyPhone      String?
  companyEmail      String?
  internalNotes     String?
  consentAccepted   Boolean          @default(false)
  assignedToId      String?
  assignedTo        User?            @relation("AssignedReferrals", fields: [assignedToId], references: [id])
  source            ReferralSource   @default(SITE)
  preReferralId     String?          @unique
  preReferral       PublicReferralRequest? @relation(fields: [preReferralId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exams             ReferralExam[]
  appointments      Appointment[]
  documents         Document[]
  referralDocuments ReferralDocument[]
  statusHistory     ReferralStatusHistory[]
}

model ReferralStatusHistory {
  id          String          @id @default(cuid())
  referralId  String
  referral    Referral        @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromStatus  ReferralStatus?
  toStatus    ReferralStatus
  notes       String?
  changedById String?
  changedBy   User?           @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())
}

model ReferralDocument {
  id           String              @id @default(cuid())
  referralId   String
  referral     Referral            @relation(fields: [referralId], references: [id], onDelete: Cascade)
  type         ReferralDocumentType @default(OUTRO)
  fileName     String
  fileUrl      String
  uploadedById String?
  uploadedBy   User?               @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime            @default(now())
}

model ReferralExam {
  id                String            @id @default(cuid())
  referralId        String
  referral          Referral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  examId            String?
  exam              Exam?             @relation(fields: [examId], references: [id])
  examName          String
  category          ExamCategory
  status            ReferralExamStatus @default(PENDENTE)
  resultAvailableAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
}

model Appointment {
  id               String            @id @default(cuid())
  title            String
  protocol         String?
  scheduledAt      DateTime
  endAt            DateTime?
  status           AppointmentStatus @default(AGENDADO)
  clinicalExamType ClinicalExamType?
  type             String?
  notes            String?
  internalNotes    String?
  attendanceNotes  String?
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  patientId        String?
  patient          Patient?          @relation(fields: [patientId], references: [id])
  referralId       String?
  referral         Referral?         @relation(fields: [referralId], references: [id])
  professionalId   String?
  professional     User?             @relation("AppointmentProfessional", fields: [professionalId], references: [id])
  roomName         String?
  createdByUserId  String?
  createdBy        User?             @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  exams            AppointmentExam[]
  history          AppointmentHistory[]
}

model AppointmentExam {
  id            String             @id @default(cuid())
  appointmentId String
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam                 @relation(fields: [examId], references: [id])
  status        ReferralExamStatus   @default(PENDENTE)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @default(now()) @updatedAt

  @@unique([appointmentId, examId])
}

model AppointmentHistory {
  id                String                   @id @default(cuid())
  appointmentId     String
  appointment       Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  action            AppointmentHistoryAction
  fromStatus        AppointmentStatus?
  toStatus          AppointmentStatus?
  notes             String?
  performedByUserId String?
  performedBy       User?                    @relation(fields: [performedByUserId], references: [id])
  createdAt         DateTime                 @default(now())
}

model Lead {
  id            String     @id @default(cuid())
  type          LeadType   @default(ORCAMENTO)
  status        LeadStatus @default(NOVO)
  name          String
  email         String?
  phone         String?
  companyName   String?
  message       String?
  estimatedValue Float?
  notes         String?
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Document {
  id         String         @id @default(cuid())
  title      String
  type       DocumentType
  status     DocumentStatus @default(PENDENTE)
  fileUrl    String?
  notes      String?
  companyId  String?
  company    Company?       @relation(fields: [companyId], references: [id])
  patientId  String?
  patient    Patient?       @relation(fields: [patientId], references: [id])
  referralId String?
  referral   Referral?      @relation(fields: [referralId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PublicReferralRequest {
  id                  String                      @id @default(cuid())
  protocol            String                      @unique
  companyName         String
  companyDocument     String?
  responsibleName     String
  whatsapp            String
  email               String?
  employeeName        String
  employeeDocument    String?
  employeeRole        String
  clinicalExamType    PreReferralClinicalExamType
  examSelectionMode   ExamSelectionMode
  selectedExams       String[]
  notes               String?
  consentAccepted     Boolean                     @default(false)
  status              PreReferralStatus           @default(NOVO)
  source              String                      @default("site_pre_referral")
  assignedToId        String?
  assignedTo          User?                       @relation("AssignedPreReferrals", fields: [assignedToId], references: [id])
  convertedReferralId String?
  referral            Referral?
  history             PreReferralHistory[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
}

model PreReferralHistory {
  id            String                @id @default(cuid())
  preReferralId String
  preReferral   PublicReferralRequest @relation(fields: [preReferralId], references: [id], onDelete: Cascade)
  action        String
  fromStatus    PreReferralStatus?
  toStatus      PreReferralStatus?
  notes         String?
  performedById String?
  performedBy   User?                 @relation(fields: [performedById], references: [id])
  createdAt     DateTime              @default(now())
}

model ContactMessage {
  id              String                @id @default(cuid())
  name            String
  email           String?
  phone           String
  company         String?
  subject         String
  message         String
  consentAccepted Boolean               @default(false)
  source          String                @default("site_contato")
  status          ContactMessageStatus  @default(NOVO)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}
