}

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
